@article{Cardano2016,
  title = {Statistical Moments of Quantum-Walk Dynamics Reveal Topological Quantum Transitions},
  author = {Cardano, Filippo and Maffei, Maria and Massa, Francesco and Piccirillo, Bruno and {de Lisio}, Corrado and De Filippis, Giulio and Cataudella, Vittorio and Santamato, Enrico and Marrucci, Lorenzo},
  year = 2016,
