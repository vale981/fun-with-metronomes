@article{Li2018,
  title = {Concepts of Quantum Non-{{Markovianity}}: {{A}} Hierarchy},
  shorttitle = {Concepts of Quantum Non-{{Markovianity}}},
  author = {Li, Li and Hall, Michael J. W. and Wiseman, Howard M.},
  year = 2018,
