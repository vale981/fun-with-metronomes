@article{Lim2023,
  title = {Oscillating Bound States in Non-{{Markovian}} Photonic Lattices},
  author = {Lim, Kian Hwee and Mok, Wai-Keong and Kwek, Leong-Chuan},
  year = 2023,
  month = feb,
  journal = {Phys. Rev. A},
  volume = {107},
