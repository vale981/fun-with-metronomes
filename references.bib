  author = {Zhang, Chunqi and Feng, Lishuang and Jiao, Hongchen and Liu, Ning and Zhang, Yonggui and Wang, Xiao},
  year = 2019,
  month = jul,
  journal = {Appl. Opt., AO},
  volume = {58},
  number = {21},
  pages = {5817--5822},
