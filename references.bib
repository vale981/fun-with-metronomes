@article{Schnyder2008,
  title = {Classification of Topological Insulators and Superconductors in Three Spatial Dimensions},
  author = {Schnyder, Andreas P. and Ryu, Shinsei and Furusaki, Akira and Ludwig, Andreas W. W.},
  year = 2008,
  month = nov,
  journal = {Phys. Rev. B},
  volume = {78},
