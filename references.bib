  file = {/home/hiro/Zotero/storage/9RPFNILZ/Andrade et al. - 2022 - Shortcuts to adiabatic population inversion via time-rescaling stability and thermodynamic cost.pdf;/home/hiro/Zotero/storage/JX4UTHI6/2205.html}
