  urldate = {2023-09-01},
  abstract = {The quantum mixing time is a critical factor affecting the efficiency of quantum sampling and algorithm performance. It refers to the minimum time required for a quantum walk to approach its limiting distribution closely and has implications across the areas of quantum computation. This work focuses on the continuous time quantum walk mixing on a regular graph, evolving according to the unitary map \$U = e\textasciicircum\textbraceleft i \textbackslash Bar\textbraceleft A\textbraceright t\textbraceright\$, where the Hamiltonian \$\textbackslash Bar\textbraceleft A\textbraceright\$ is the normalized adjacency matrix of the graph. In\textasciitilde [Physical Review A 76, 042306 (2007).], Richter previously showed that this walk mixes in time \$O(n d\textbackslash log\textbraceleft (d)\textbackslash log\textbraceleft (1/\textbackslash epsilon)\textbraceright\textbraceright )\$ with \$O( \textbackslash log\textbraceleft (d)\textbackslash log\textbraceleft (1/\textbackslash epsilon)\textbraceright\textbraceright )\$ intermediate measurements when the graph is the \$d-\$dimensional periodic lattice \$\textbackslash mathbb\textbraceleft Z\textbraceright\_\textbraceleft n\textbraceright\textbackslash times \textbackslash mathbb\textbraceleft Z\textbraceright\_\textbraceleft n\textbraceright\textbackslash times \textbackslash dots \textbackslash times \textbackslash mathbb\textbraceleft Z\textbraceright\_\textbraceleft n\textbraceright\$. We extend this analysis to the periodic lattice \$\textbackslash mathcal\textbraceleft L\textbraceright{} = \textbackslash mathbb\textbraceleft Z\textbraceright\_\textbraceleft n\_1\textbraceright\textbackslash times \textbackslash mathbb\textbraceleft Z\textbraceright\_\textbraceleft n\_2\textbraceright\textbackslash times \textbackslash dots \textbackslash times \textbackslash mathbb\textbraceleft Z\textbraceright\_\textbraceleft n\_d\textbraceright\$, relaxing the assumption that \$n\_i\$ are identical.We provide two quantum walks on periodic lattices that achieve faster mixing compared to classical random walks: 1. A coordinate-wise quantum walk that mixes in \$O\textbackslash Big(\textbackslash Big(\textbackslash sum\_\textbraceleft i=1\textbraceright\textasciicircum\textbraceleft d\textbraceright{} n\_i \textbackslash Big) \textbackslash log\textbraceleft (d/\textbackslash epsilon)\textbraceright\textbackslash Big)\$ time with \$O(d \textbackslash log(d/\textbackslash epsilon))\$ measurements. 2. A continuous-time quantum walk with \$O(\textbackslash log(1/\textbackslash epsilon))\$ measurements that conjecturally mixes in \$O(\textbackslash sum\_\textbraceleft i=1\textbraceright\textasciicircum d n\_i(\textbackslash log(n\_1))\textasciicircum 2 \textbackslash log(1/\textbackslash epsilon))\$ time. Our results demonstrate a quadratic speedup over the classical~ mixing time \$O(dn\_1\textasciicircum 2 \textbackslash log(d/\textbackslash epsilon))\$ on the generalized periodic lattice \$\textbackslash mathcal\textbraceleft L\textbraceright\$. We have provided analytical evidence and numerical simulations to support the conjectured faster mixing time of the continuous-time quantum walk algorithm.Making progress towards proving the general conjecture that quantum walks on regular graphs mix in \$O(\textbackslash delta\textasciicircum\textbraceleft -1/2\textbraceright{} \textbackslash log(N) \textbackslash log(1/\textbackslash epsilon))\$ time, where \$\textbackslash delta\$ is the spectral gap and \$N\$ is the number of vertices.},
  langid = {english},
  keywords = {Continuous time quantum walks,Mixing time,Periodic lattices},
  file = {/home/hiro/Zotero/storage/NATJPN2P/Dhamapurkar and Deng - 2023 - Quantum Walk Mixing is Faster than Classical on Pe.pdf}
}

