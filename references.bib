@phdthesis{Christoforou,
  title = {Strong Coupling of a Single Ion to an Optical Fibre Cavity},
  author = {Christoforou, Costas Marios},
  abstract = {Achieving strong coupling between a single ion and a cavity is an important condition for cavity quantum electrodynamics, mainly for its applications in quantum networks, quantum computing and quantum interfaces. While strong coupling has been achieved in various physical systems, so far it remained elusive for single atomic ions. In this thesis I present the first observation of strong coupling between a single ion and an optical cavity. Our system is a hybrid system where a fibre based Fabry-P\textasciiacute erot cavity was incorporated to a 3D Paul trap. The position of the ion, relative to the cavity mode, was adjusted by applying additional rf signals on the radial electrodes of the trap, in order to maximise the coupling between the ion and the cavity. The coupling strength was measured to be g = 2{$\pi\times$}(12.3\textpm 0.1) MHz, which exceeds both the atomic decay rate, {$\gamma$} = 2{$\pi$} \texttimes{} 11.5 MHz, and the cavity decay rate, {$\kappa$} = 2{$\pi$} \texttimes{} (4.1 \textpm{} 0.1) MHz, placing the ion-cavity coupling in the strong coupling regime. Cavity assisted Raman spectroscopy was used to precisely characterize the ion-cavity coupling strength, and observe a spectrum featuring the normal mode splitting in the cavity transmission due to the ion-cavity interaction. Due to geometric constraints in our trap, Doppler cooling was not optimal along the cavity axis, hindering the localisation of the ion and thus its coupling to the cavity. To improve the localisation of the ion, cavity cooling was used to efficiently cool the ion along the cavity axis. By using cavity cooling, we obtain an enhanced ion-cavity coupling of g0 = 2{$\pi$} \texttimes{} (16.7 \textpm{} 0.1) MHz, compared with g0 = 2{$\pi$} \texttimes{} (15.2 \textpm{} 0.1) MHz when using only Doppler cooling.},
  langid = {english},
  keywords = {No DOI found},
  file = {/home/hiro/Zotero/storage/6GBN6C29/Christoforou - Strong coupling of a single ion to an optical ﬁbre cavity.pdf}
}

