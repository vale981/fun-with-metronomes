@article{Chang2020,
  title = {Observation of {{Three-Photon Spontaneous Parametric Down-Conversion}} in a {{Superconducting Parametric Cavity}}},
  author = {Chang, C. W. Sandbo and Sab{\'i}n, Carlos and {Forn-D{\'i}az}, P. and Quijandr{\'i}a, Fernando and Vadiraj, A. M. and Nsanzineza, I. and Johansson, G. and Wilson, C. M.},
  year = 2020,
