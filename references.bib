@article{Kawabata2019a,
  title = {Symmetry and {{Topology}} in {{Non-Hermitian Physics}}},
  author = {Kawabata, Kohei and Shiozaki, Ken and Ueda, Masahito and Sato, Masatoshi},
  year = 2019,
  month = oct,
  journal = {Phys. Rev. X},
