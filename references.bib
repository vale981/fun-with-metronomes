  pages = {012215},
  issn = {2469-9926, 2469-9934},
  doi = {10.1103/PhysRevA.102.012215},
  urldate = {2022-11-07},
  abstract = {We extend non-Hermitian topological quantum walks on a Su-Schrieffer-Heeger (SSH) lattice [Phys. Rev. Lett. 102, 065703 (2009)] to the case of non-Markovian evolution. This non-Markovian model is established by coupling each unit cell in the SSH lattice to a reservoir formed by a quasicontinuum of levels. We find a topological transition in this model even in the case of non-Markovian evolution where the walker may visit the reservoir and return to the SSH lattice at a later time. The existence of a topological transition does, however, depend on the low-frequency properties of the reservoir, characterized by a spectral density J({$\epsilon$}) {$\propto$} \textbar{$\epsilon\vert\alpha$}. In particular, we find a robust topological transition for a sub-Ohmic ({$\alpha$} {$<$} 1) and Ohmic ({$\alpha$} = 1) reservoir, but no topological transition for a super-Ohmic ({$\alpha$} {$>$} 1) reservoir. This behavior is directly related to the well-known localization transition for the spin-boson model. We confirm the presence of non-Markovian dynamics by explicitly evaluating a measure of Markovianity for this model.},
  langid = {english},
  file = {/home/hiro/Zotero/storage/9JUGVSF4/10.1103@PhysRevA.102.012215.pdf.pdf;/home/hiro/Zotero/storage/NDMPP3AC/Ricottone et al. - 2020 - Topological transition of a non-Markovian dissipat.pdf}
}

