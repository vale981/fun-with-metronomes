\cs_new_protected:Nn \__comm_render_note:n {
  \bool_if:NTF \g_comm_final_bool {
    \tl_if_blank:nF { \l__comm_target_tl } {
      \l__comm_target_tl
    }
  }{
    \tl_set_eq:NN \l__comm_line_color_tl \l__comm_color_tl
    \int_gincr:N \g__comm_count_int
    \int_set_eq:NN \l__comm_id_int \g__comm_count_int

    % Compute stable MD5 hash for the comment thread (based on initiator, target text, and initial comment body)
    \tl_set:Nx \l_comm_current_thread_hash_tl {
      \str_mdfive_hash:e {
        \tl_to_str:V \l__comm_initiator_tl / \tl_to_str:V \l__comm_target_tl / \tl_to_str:V \l__comm_initial_body_tl
      }
    }

    % Get or generate timestamp for this comment thread
    \tl_if_blank:oTF { \l__comm_target_tl } {
      \tl_clear:N \l_comm_timestamp_tl
    }{
      \prop_get:NxN \g_comm_loaded_timestamps_prop { \l_comm_current_thread_hash_tl } \l_comm_timestamp_tl
      \quark_if_no_value:NT \l_comm_timestamp_tl {
        \tl_set:Nx \l_comm_timestamp_tl { \__comm_format_datetime: }
      }
      \prop_gput:Nxx \g_comm_resolved_timestamps_prop { \l_comm_current_thread_hash_tl } { \l_comm_timestamp_tl }
    }

    % Marker
    \zsaveposy{commsrc-\int_use:N \l__comm_id_int}%
    \zlabel{commsrcpage-\int_use:N \l__comm_id_int}%
    \hypertarget{commsrc-\int_use:N \l__comm_id_int}{}%
    \tikz[remember~picture,overlay,baseline]{
      \node[anchor=base,inner~sep=0pt,outer~sep=0pt](commsrc-\int_use:N \l__comm_id_int){\strut};
    }

    % Measure box height of the comment and cache the typeset box
    \bool_set_eq:NN \l_comm_save_first_bool \l_comm_first_reply_bool
    \hbox_set:Nn \l_comm_render_box {
      \__comm_draw_box:Vnn \l__comm_body_tl { \int_use:N \l__comm_id_int } { \l_comm_timestamp_tl }
    }
    \bool_gset_eq:NN \l_comm_first_reply_bool \l_comm_save_first_bool
    \dim_set:Nn \l_comm_box_height_dim { \box_ht:N \l_comm_render_box + \box_dp:N \l_comm_render_box }

    % Detect position and write to aux (for next run)
    \begin{tikzpicture}[remember~picture, overlay]
    \path (commsrc-\int_use:N \l__comm_id_int.center); \pgfgetlastxy{\xn}{\yn}
    \path (current~page.center); \pgfgetlastxy{\xc}{\yc}
    \dim_compare:nNnTF { \xn } < { \xc } {
      \tl_set:Nn \l_tmpa_tl { L }
    }{
      \tl_set:Nn \l_tmpa_tl { R }
    }
    \iow_now:Nx \@auxout {
      \exp_not:N \expandafter \exp_not:N \gdef \exp_not:N \csname commside \int_use:N \l__comm_id_int \exp_not:N \endcsname { \l_tmpa_tl }
      \exp_not:N \commrecord { \int_use:N \l__comm_id_int } { \zref@extractdefault { commsrcpage-\int_use:N \l__comm_id_int } { abspage } { \thepage } } { \zposy{commsrc-\int_use:N \l__comm_id_int}sp } { \the\l_comm_box_height_dim }
      \exp_not:N \commreportentry { \int_use:N \l__comm_id_int } { \zref@extractdefault { commsrcpage-\int_use:N \l__comm_id_int } { abspage } { \thepage } } { \tl_to_str:N \l__comm_initiator_tl } { \l_comm_current_thread_hash_tl } { \tl_to_str:N \l__comm_target_tl } { \exp_not:V \l__comm_snippet_tl } { \l_comm_state_tl } { \l_comm_timestamp_tl }
    }
  \end{tikzpicture}

  % Use the recorded side or default
  \cs_if_exist:cTF { commside \int_use:N \l__comm_id_int } {
    \str_if_eq:eeTF { \use:c { commside \int_use:N \l__comm_id_int } } { L } {
       \reversemarginpar
    }{
       \normalmarginpar
    }
  }{
    \normalmarginpar
  }

  % Fetch calculated elastic shift or default to 0pt
  \cs_if_exist:cTF { g__comm_shift_ \int_use:N \l__comm_id_int _dim } {
    \dim_set_eq:Nc \l_comm_shift_dim { g__comm_shift_ \int_use:N \l__comm_id_int _dim }
  }{
    \dim_set:Nn \l_comm_shift_dim { 0pt }
  }

  % Placement in margin with shift (reuse the cached typeset box)
  \use:x {
    \exp_not:N \marginnote
      { \exp_not:N \box_use_drop:N \exp_not:N \l_comm_render_box }
      [ \dim_eval:n { #1 + \l_comm_shift_dim } ]
  }

  \normalmarginpar % Reset

  \tl_if_blank:nF { \l__comm_target_tl } {
    \group_begin:
    \color{\l__comm_line_color_tl} \l__comm_target_tl
    \group_end:
  }

  % Draw the connecting line (only if both source and destination end up on the same page)
  \int_set:Nn \l_tmpa_int { \zref@extractdefault { commsrcpage-\int_use:N \l__comm_id_int } { abspage } { 0 } }
  \int_set:Nn \l_tmpb_int { \zref@extractdefault { commdest-\int_use:N \l__comm_id_int } { abspage } { 1 } }
  \int_compare:nNnT { \l_tmpa_int } = { \l_tmpb_int } {
    \use:x {
      \exp_not:N \begin{tikzpicture}[remember~picture,overlay]
        \exp_not:N \path (commsrc-\int_use:N \l__comm_id_int.center); \exp_not:N \pgfgetlastxy{\exp_not:N \commxsrc}{\exp_not:N \commysrc}
        \exp_not:N \path (commdest-\int_use:N \l__comm_id_int.center); \exp_not:N \pgfgetlastxy{\exp_not:N \commxdest}{\exp_not:N \commydest}
        \exp_not:N \path (current~page.center); \exp_not:N \pgfgetlastxy{\exp_not:N \commxc}{\exp_not:N \commyc}
        \exp_not:N \ifdim \exp_not:N \commxdest > \exp_not:N \commxc
          \exp_not:N \draw[semithick, \l__comm_line_color_tl, opacity=0.8]
            ($(current~page.center |- commsrc-\int_use:N \l__comm_id_int.base) + (0.5*\exp_not:N \textwidth, 0)$)
            -- (commdest-\int_use:N \l__comm_id_int.west);
        \exp_not:N \else
          \exp_not:N \draw[semithick, \l__comm_line_color_tl, opacity=0.8]
            ($(current~page.center |- commsrc-\int_use:N \l__comm_id_int.base) - (0.5*\exp_not:N \textwidth, 0)$)
            -- (commdest-\int_use:N \l__comm_id_int.east);
        \exp_not:N \fi
      \exp_not:N \end{tikzpicture}
    }
  }
}
}

\cs_generate_variant:Nn \prop_get:NnN { NoN }

\box_new:N \l_comm_scratch_box
\box_new:N \l_comm_render_box

\NewDocumentCommand{\commreply}{m m}{
  \bool_gset_false:N \g_comm_reply_handled_bool
  \group_begin:
    \bool_set_eq:NN \l_comm_save_first_bool \l_comm_first_reply_bool
    % Dry run in a scratch vbox to detect commentator macros
    \vbox_set:Nn \l_comm_scratch_box {
      \hsize=\dimexpr \marginparwidth - 2\fboxsep - 1.2pt \relax
      #2
    }
    \bool_gset_eq:NN \l_comm_first_reply_bool \l_comm_save_first_bool
  \group_end:

  \bool_if:NTF \g_comm_reply_handled_bool {
    % It was self-formatted: execute it directly in the main stream
    #2
  }{
    % Plain text: format with default author
    \use:c { #1 reply } { #2 }
  }
}

\cs_new_protected:Nn \__comm_process:nn {
  \bool_gset_true:N \l_comm_first_reply_bool

  \seq_get_left:NN \l__comm_args_seq \l_tmpa_tl
  \seq_pop_left:NN \l__comm_args_seq \l_tmpb_tl

  \tl_set_eq:NN \l__comm_target_tl \l_tmpa_tl

  \prop_clear:N \l_comm_replies_prop
  \seq_if_empty:NTF \l__comm_args_seq {
    \prop_put:Nnn \l_comm_replies_prop { 1/author } { #1 }
    \prop_put:Nox \l_comm_replies_prop { 1/body } { \l_tmpa_tl }
    \tl_set_eq:NN \l__comm_initial_body_tl \l_tmpa_tl
    \int_set:Nn \l_comm_replies_count { 1 }
    \tl_clear:N \l__comm_target_tl
  }{
    \prop_get:NnN \g_comm_commentators_prop { #1/partner } \l_initiator_partner_id_tl
    \int_set:Nn \l_comm_replies_count { \seq_count:N \l__comm_args_seq }

    \int_step_inline:nn { \l_comm_replies_count } {
      \int_if_odd:nTF { ##1 } {
        \tl_set:Nn \l_curr_id_tl { #1 }
      }{
        \tl_set_eq:NN \l_curr_id_tl \l_initiator_partner_id_tl
        \tl_if_empty:NT \l_curr_id_tl {
          \tl_set:Nn \l_curr_id_tl { #1 }
        }
      }
      \prop_put:Nox \l_comm_replies_prop { ##1/author } { \l_curr_id_tl }
      \prop_put:Nox \l_comm_replies_prop { ##1/body } { \seq_item:Nn \l__comm_args_seq { ##1 } }
    }
    \tl_set:Nx \l__comm_initial_body_tl { \seq_item:Nn \l__comm_args_seq { 1 } }
  }

  % Replay/Build \l__comm_body_tl from property list with strict expansion protection
  \tl_clear:N \l__comm_body_tl
  \int_step_inline:nn { \l_comm_replies_count } {
    \prop_get:NnN \l_comm_replies_prop { ##1/author } \l_author_tl
    \prop_get:NnN \l_comm_replies_prop { ##1/body } \l_body_tl
    \tl_put_right:Nx \l__comm_body_tl {
      \exp_not:N \commreply { \l_author_tl } { \exp_not:o \l_body_tl }
    }
  }

  \prop_get:NnN \g_comm_commentators_prop { #1/name } \l__comm_initiator_tl
  \prop_get:NnN \g_comm_commentators_prop { #1/color } \l__comm_initiator_color_tl
  \tl_set:Nx \l__comm_snippet_tl {
    \seq_if_empty:NTF \l__comm_args_seq {
      \exp_not:N \commreply { #1 } { \exp_not:V \l__comm_body_tl }
    }{
      \exp_not:V \l__comm_body_tl
    }
  }

  \prop_get:NnN \g_comm_commentators_prop { #1/color } \l__comm_color_tl
  \__comm_render_note:n { #2 }
}

\cs_new_protected:Nn \__comm_register_commentator:nnnn {
  \prop_gput:Nnn \g_comm_commentators_prop { #1/name } { #2 }
  \prop_gput:Nnn \g_comm_commentators_prop { #1/color } { #3 }
  \prop_gput:Nnn \g_comm_commentators_prop { #1/partner } { #4 }

  % Main alternating command: \<id> (e.g. \bill)
  \exp_args:Nc \NewDocumentCommand { #1 } { s t+ } {%
    \bool_if:NTF \l_comm_in_conversation_bool {%
      \bool_if:NTF ##1 {%
        \use:c { #1 reply } { * }%
      }{%
        \bool_if:NTF ##2 {%
          \use:c { #1 reply } { + }%
        }{%
          \use:c { __comm_reply_only_ #1 }%
        }%
      }%
    }{%
      % Thread starter
      \bool_if:NTF ##1 {
        \tl_gset:Nn \g_comm_current_state_tl { resolved }
      }{
        \bool_if:NTF ##2 {
          \tl_gset:Nn \g_comm_current_state_tl { to_review }
        }{
          \tl_gset:Nn \g_comm_current_state_tl { unresolved }
        }
      }
      \use:c { __comm_impl_ #1 }%
    }%
  }

  \exp_args:Nc \NewDocumentCommand { __comm_reply_only_ #1 } { m } {%
    \use:c { #1 reply } { ##1 }%
  }

  % The internal implementation command parses the rest of the arguments
  \exp_args:Nc \NewDocumentCommand { __comm_impl_ #1 } { m +g +g +g +g +g +g O{0pt} } {%
    \tl_set_eq:NN \l_comm_state_tl \g_comm_current_state_tl
    \seq_clear:N \l__comm_args_seq%
    \seq_put_right:Nn \l__comm_args_seq { ##1 }%
    \IfValueT { ##2 } { \seq_put_right:Nn \l__comm_args_seq { ##2 } }%
    \IfValueT { ##3 } { \seq_put_right:Nn \l__comm_args_seq { ##3 } }%
    \IfValueT { ##4 } { \seq_put_right:Nn \l__comm_args_seq { ##4 } }%
    \IfValueT { ##5 } { \seq_put_right:Nn \l__comm_args_seq { ##5 } }%
    \IfValueT { ##6 } { \seq_put_right:Nn \l__comm_args_seq { ##6 } }%
    \IfValueT { ##7 } { \seq_put_right:Nn \l__comm_args_seq { ##7 } }%
    \__comm_process:nn { #1 } { ##8 }%
  }

  % Inline formatter: \<id>reply (e.g. \billreply)
  \exp_args:Nc \NewDocumentCommand { #1 reply } { m } {%
    \bool_gset_true:N \g_comm_reply_handled_bool%
    \bool_if:NTF \l_comm_first_reply_bool {%
      \bool_gset_false:N \l_comm_first_reply_bool%
    }{%
      \par\vspace{3pt}%
    }%
    \__comm_format_reply:nnnn { #1 } { #2 } { #3 } { ##1 }%
  }
}

\cs_new_protected:Nn \__comm_format_reply:nnnn {
  \int_incr:N \l_comm_reply_idx_int

  % Compute stable MD5 hash for the reply content (based on author and reply body)
  \tl_set:Nx \l_comm_reply_hash_tl {
    \str_mdfive_hash:n {
      #1 / #2 / #4
    }
  }

  \prop_get:NxN \g_comm_loaded_timestamps_prop { \l_comm_reply_hash_tl } \l_comm_reply_timestamp_tl
  \quark_if_no_value:NT \l_comm_reply_timestamp_tl {
    \tl_set:Nx \l_comm_reply_timestamp_tl { \__comm_format_datetime: }
  }
  \prop_gput:Nxx \g_comm_resolved_timestamps_prop {  \l_comm_reply_hash_tl } { \l_comm_reply_timestamp_tl }

  \textcolor { #3 } {
    \textbf { #2 }
    \bool_if:NT \g_comm_timestamps_bool {
      \textnormal{~\textcolor{gray}{\tiny~[ \__comm_render_local_datetime:V \l_comm_reply_timestamp_tl ]}}
    }
    \textbf { : }~#4
  }
}

