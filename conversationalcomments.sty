}

\NewDocumentCommand{\conversation}{s t+}{
  \bool_if:NTF #1 {
    \tl_gset:Nn \g_comm_current_state_tl { resolved }
  }{
    \bool_if:NTF #2 {
      \tl_gset:Nn \g_comm_current_state_tl { to_review }
    }{
      \tl_gset:Nn \g_comm_current_state_tl { unresolved }
    }
  }
  \__comm_impl_conversation
}

\NewDocumentCommand{\__comm_impl_conversation}{m +m O{0pt}}{
  \group_begin:
  \tl_set_eq:NN \l_comm_state_tl \g_comm_current_state_tl
  \bool_gset_true:N \l_comm_first_reply_bool
  \tl_set:Nn \l__comm_target_tl { #1 }
  \tl_set:Nn \l__comm_body_tl { #2 }
  \tl_trim_spaces:N \l__comm_body_tl
  \tl_set:Nn \l__comm_initial_body_tl { #2 }
  \tl_set:Nn \l__comm_color_tl { gray } % Neutral rim for multi-author
  \tl_set:Nn \l__comm_initiator_tl { Group }
  \tl_set:Nn \l__comm_initiator_color_tl { gray }
  \tl_set_eq:NN \l__comm_snippet_tl \l__comm_body_tl
  \__comm_render_note:n { #3 }
  \group_end:
}

\cs_new_protected:Nn \__comm_render_report_entry:nnnnnnnnn {
  \group_begin:
  \tl_set:Nn \l_comm_current_thread_hash_tl { #4 }
  \tl_if_blank:nF { #5 } {
    \prop_gput:Nxx \g_comm_resolved_timestamps_prop { \l_comm_current_thread_hash_tl } { #8 }
  }
  \tl_set:Nn \l_curr_filter_tl { #9 }
  \bool_set_true:N \l_comm_should_print_bool

  \tl_set:Nn \l_curr_state_tl { #7 }
  % Normalize old true/false values for backwards compatibility
  \str_if_eq:eeT { \l_curr_state_tl } { true } { \tl_set:Nn \l_curr_state_tl { resolved } }
  \str_if_eq:eeT { \l_curr_state_tl } { false } { \tl_set:Nn \l_curr_state_tl { unresolved } }

  \str_if_eq:VnT \l_curr_filter_tl { unresolved } {
    \str_if_eq:eeF { \l_curr_state_tl } { unresolved } {
      \bool_set_false:N \l_comm_should_print_bool
    }
  }
  \str_if_eq:VnT \l_curr_filter_tl { resolved } {
    \str_if_eq:eeF { \l_curr_state_tl } { resolved } {
      \bool_set_false:N \l_comm_should_print_bool
    }
  }

  % Check if filter is to_review/to-review
  \bool_set_false:N \l_tmpa_bool
  \str_if_eq:VnT \l_curr_filter_tl { to_review } { \bool_set_true:N \l_tmpa_bool }
  \str_if_eq:VnT \l_curr_filter_tl { to-review } { \bool_set_true:N \l_tmpa_bool }
  \str_if_eq:VnT \l_curr_filter_tl { to~review } { \bool_set_true:N \l_tmpa_bool }

  \bool_if:NT \l_tmpa_bool {
    \str_if_eq:eeF { \l_curr_state_tl } { to_review } {
      \bool_set_false:N \l_comm_should_print_bool
    }
  }

  \bool_if:NT \l_comm_should_print_bool {
    \vspace{8pt}
    \noindent
    \int_set:Nn \l__comm_id_int { #1 }
    \int_set:Nn \l_comm_reply_idx_int { 0 }
    \bool_set_true:N \l_comm_first_reply_bool
    \tl_set:Nn \l_comm_current_thread_hash_tl { #4 }
    \hyperlink{commsrc-#1}{\textbf{[\##1]}}~on~page~\hyperlink{commsrc-#1}{#2}~~---~~%
    \str_if_eq:eeTF { \l_curr_state_tl } { resolved } {
      \textcolor{gray}{\textbf{[Resolved]}}
    }{
      \str_if_eq:eeTF { \l_curr_state_tl } { to_review } {
        \textcolor{orange}{\textbf{[To~Review]}}
      }{
        \textcolor{red}{\textbf{[Unresolved]}}
      }
    }
    \par\vspace{3pt}
    \bool_if:NT \g_comm_timestamps_bool {
      \tl_if_blank:nF { #5 } {
        \hspace*{1.5em}\textbf{Date:}~\texttt{\__comm_render_local_datetime:n { #8 }} \par\vspace{2pt}
      }
    }
    \tl_if_blank:nF { #5 } {
      \hspace*{1.5em}\textbf{Target:}~\texttt{\tl_to_str:n { #5 }} \par\vspace{2pt}
    }
    \hspace*{1.5em}\textbf{Comments:}~#6
    \par
  }
  \group_end:
}

\NewDocumentCommand{\printconversations}{O{unresolved}}{
