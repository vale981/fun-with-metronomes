      \setlength{\parindent}{0pt}%
      \str_if_eq:VnT \l_comm_state_tl { resolved } {
        \textcolor{gray}{\textbf{[Resolved]}} \par\vspace{2pt}
      }
      \str_if_eq:VnT \l_comm_state_tl { to_review } {
        \textcolor{orange}{\textbf{[To~Review]}} \par\vspace{2pt}
      }
      \ignorespaces #1%
      \bool_if:NT \g_comm_timestamps_bool {
        \tl_if_blank:oF { \l__comm_target_tl } {
          \par\vspace{3pt}
          \hfill{\tiny\textcolor{gray}{\__comm_render_local_datetime:n { #3 }}}%
        }
      }
    };
  \end{tikzpicture}
  \group_end:
}
